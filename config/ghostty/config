# Auto-generated by NixOS config

shell-integration = zsh
shell-integration-features = cursor,sudo,ssh-terminfo
notify-on-command-finish = unfocused

keybind = ctrl+z=close_surface
keybind = ctrl+c>ctrl+c=end_key_sequence
keybind = ctrl+c>r=reload_config
keybind = ctrl+c>y=copy_to_clipboard
keybind = ctrl+c>p=paste_from_clipboard
keybind = ctrl+c>/=start_search
keybind = ctrl+c>u=undo
keybind = ctrl+c>U=redo

# Splits
keybind = ctrl+c>s=new_split:down
keybind = ctrl+c>v=new_split:right
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right
keybind = ctrl+c>h=goto_split:left
keybind = ctrl+c>j=goto_split:down
keybind = ctrl+c>k=goto_split:up
keybind = ctrl+c>l=goto_split:right
keybind = ctrl+c>==equalize_splits

# Tabs
keybind = ctrl+c>t=toggle_tab_overview
keybind = ctrl+c>c=new_tab
keybind = ctrl+c>d=close_surface
keybind = ctrl+c>1=goto_tab:1
keybind = ctrl+c>2=goto_tab:2
keybind = ctrl+c>3=goto_tab:3
keybind = ctrl+c>4=goto_tab:4
keybind = ctrl+c>5=goto_tab:5
keybind = ctrl+c>6=goto_tab:6
keybind = ctrl+c>7=goto_tab:7
keybind = ctrl+c>8=goto_tab:8
keybind = ctrl+c>9=goto_tab:9
keybind = ctrl+c>0=goto_tab:9

shell-integration = detect
shell-integration-features = sudo, title, ssh-terminfo, no-cursor
